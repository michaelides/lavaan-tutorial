root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{qmd,md,yml,yaml,R,r}]
indent_style = space
indent_size = 2

[*.{Rmd,rmd}]
indent_style = space
indent_size = 2

[*.R]
indent_style = space
indent_size = 2

[Makefile]
indent_style = tab
